# Analytics (PostHog). Copy to .env.local and fill in to enable tracking.
# Without a key, all analytics no-ops (safe for dev/forks).
#
# Get the key at app.posthog.com -> Project settings -> Project API Key.
# This key is public/client-side by design (it ships in the bundle).
VITE_POSTHOG_KEY=
# Use https://eu.i.posthog.com if you created the project on EU cloud.
VITE_POSTHOG_HOST=https://us.i.posthog.com
